# =============================================================
# backup.env — ค่าสำหรับ backup-databases.sh
# =============================================================
# ติดตั้ง:  cp backup.env.example /opt/wf/backup.env
#          chmod 600 /opt/wf/backup.env      ← สำคัญ! มีรหัสผ่าน
# =============================================================

# ── รหัสผ่าน (ต้องตรงกับที่ตั้งใน Coolify) ────────────────────
MSSQL_SA_PASSWORD="__SAME_AS_COOLIFY_MSSQL_SA_PASSWORD__"
MYSQL_ROOT_PASSWORD="__SAME_AS_COOLIFY_MYSQL_ROOT_PASSWORD__"

# ── ชื่อ container / database ────────────────────────────────
MSSQL_CONTAINER="mssql"
MYSQL_CONTAINER="mysql"
MSSQL_DB="dbwins_worldfert9"
MYSQL_DB="db_truckscale"

# ── ที่เก็บ + การหมุนเวียน ───────────────────────────────────
# ⚠ ตั้งไว้สำหรับเครื่อง CX23 disk 40GB — .bak.gz รอบละ ~1GB
#   เก็บสั้นบนเครื่อง แล้วส่งออก OFFSITE เป็นตัวเก็บระยะยาวแทน
#   ถ้าอัปเป็น disk 80GB+ ปรับเป็น RETAIN_DAYS=14 / WEEKLY_RETAIN_DAYS=90 ได้
BACKUP_DIR="/var/backups/wf"
RETAIN_DAYS="3"            # รายวันเก็บ 3 วัน
WEEKLY_RETAIN_DAYS="21"    # สำเนาวันอาทิตย์เก็บ 21 วัน
MIN_FREE_GB="8"            # ถ้าว่างน้อยกว่านี้ → ลบของเก่า/ยกเลิก กันดิสก์เต็ม

# ── ส่งออกนอกเครื่อง (แนะนำอย่างยิ่ง) ────────────────────────
# backup ที่อยู่บนเครื่องเดียวกับ DB ไม่ช่วยตอนดิสก์/เครื่องพัง
# ตัวอย่าง Hetzner Storage Box:
# OFFSITE_RSYNC_TARGET="u123456@u123456.your-storagebox.de:/home/wf-backup/"
#   (ต้องตั้ง ssh key ให้ root ก่อน: ssh-copy-id -p 23 u123456@u123456.your-storagebox.de)
OFFSITE_RSYNC_TARGET=""

# ── แจ้งเตือนเมื่อ backup ล้มเหลว ────────────────────────────
# Slack / Discord / LINE Notify webhook
ALERT_WEBHOOK_URL=""
