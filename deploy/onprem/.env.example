# =============================================================
# WS-Sale-App — On-Prem (.env)
# =============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า
#   Windows : copy .env.example .env
#   Linux   : cp .env.example .env
#
# สุ่มรหัสผ่าน:
#   Linux/Git Bash : openssl rand -base64 32 | tr -d '/+=' | head -c 24
#   PowerShell     : -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 24 | % {[char]$_})
#
# ⚠ ไฟล์ .env มีรหัสผ่าน — อยู่ใน .gitignore แล้ว ห้าม commit
# =============================================================

# ── โดเมน ────────────────────────────────────────────────────
# ใช้ DDNS ก็ได้ เช่น worldfert.ddns.net / worldfert-api.ddns.net
# ต้องชี้มาที่ IP สาธารณะของเครื่องนี้ และ forward port 80+443 ที่ router
APP_DOMAIN=worldfert.ddns.net
API_DOMAIN=api.worldfert.ddns.net
ACME_EMAIL=you@example.com

# ค่าที่ frontend/backend ใช้ — ต้องสอดคล้องกับโดเมนข้างบน
VITE_API_BASE_URL=https://api.worldfert.ddns.net/api
CORS_ORIGIN=https://worldfert.ddns.net

# ── ทดสอบในเครื่อง (ไม่มีโดเมน) ให้ใช้ชุดนี้แทน ────────────────
# APP_DOMAIN=localhost
# API_DOMAIN=localhost:8443
# VITE_API_BASE_URL=http://localhost/api
# CORS_ORIGIN=http://localhost

# ── รหัสผ่านฐานข้อมูล (ต้องเปลี่ยนทุกค่า) ─────────────────────
MSSQL_SA_PASSWORD=CHANGE_ME_Strong#Passw0rd
MYSQL_ROOT_PASSWORD=CHANGE_ME_MySqlRoot
MYSQL_USER=wfapp
MYSQL_PASSWORD=CHANGE_ME_MySqlApp

# ผู้ใช้ระดับ database ที่แอปใช้จริง (สร้างโดย bootstrap.sh)
#   wf_reader = อ่านอย่างเดียว · wf_owner = เขียนได้เฉพาะ schema wf (เขียน dbo ไม่ได้)
WF_READER_PASSWORD=CHANGE_ME_Reader
WF_OWNER_PASSWORD=CHANGE_ME_Owner

# ── ความลับของแอป ────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_อย่างน้อย_32_ตัวอักษร_สุ่ม
JWT_EXPIRES_IN=8h
MIGRATE_SECRET=CHANGE_ME_random
TS_INGEST_SECRET=CHANGE_ME_random

# ── ชื่อฐานข้อมูล ────────────────────────────────────────────
DB_NAME=dbwins_worldfert9
MYSQL_DATABASE=db_truckscale

# ── ปรับตามสเปกเครื่อง ───────────────────────────────────────
TZ=Asia/Bangkok
MSSQL_PID=Express
MSSQL_MEMORY_LIMIT_MB=2048      # SQL Server จำกัดตัวเอง (Express cap buffer pool 1410MB อยู่แล้ว)
MSSQL_MEM_LIMIT=3G              # limit ของ container
MYSQL_BUFFER_POOL=256M
MYSQL_MEM_LIMIT=1G
# เครื่อง RAM 16GB+ ปรับเป็น: MSSQL_MEMORY_LIMIT_MB=6144 MSSQL_MEM_LIMIT=8G MYSQL_BUFFER_POOL=1G

# ── พอร์ต ────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
# พอร์ต DB เปิดเฉพาะ 127.0.0.1 ของเครื่องนี้ (SSMS/DBeaver ต่อได้ ภายนอกต่อไม่ได้)
MSSQL_LOCAL_PORT=1433
MYSQL_LOCAL_PORT=3306

TS_SYNC_INTERVAL_MS=60000
APP_VERSION=1.0.0

# ── LINE Login (ไม่ใส่ก็ใช้งานได้ ยกเว้นปุ่ม Login with LINE) ──
# ดูวิธีตั้งค่าที่ ../LINE-LOGIN-GUIDE.md
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=
LINE_LOGIN_SUCCESS_REDIRECT=
