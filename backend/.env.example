# ── SQL Server ────────────────────────────────────────────────
DB_SERVER=.\SQLEXPRESS
DB_NAME=dbwins_worldfert9

# wf_reader = read-only, ใช้สำหรับ master data และ views
DB_USER=wf_reader
DB_PASSWORD=ChangeMe_Strong#2026

# wf_owner = full access บน schema wf (ต้องสร้างก่อน run migrate)
DB_OWNER_USER=wf_owner
DB_OWNER_PASSWORD=YOUR_WF_OWNER_PASSWORD

# ── TruckScale (MySQL — pool แยก ไม่เกี่ยวกับ DB_MODE) ─────────
# ⚠ อย่าตั้ง DB_MODE=mysql — DB_MODE ใช้คุม SQL Server (local/remote) เท่านั้น
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=db_truckscale
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── WINSpeed Import ───────────────────────────────────────────
# โฟลเดอร์ที่ WINSpeed ตั้งไว้รับ import files
WINSPEED_IMPORT_PATH=C:\WINSpeed\Import
# โฟลเดอร์ที่ backend เก็บไฟล์ที่สร้าง
EXPORT_OUTPUT_PATH=C:\wssale-exports
