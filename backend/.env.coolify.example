# =============================================================
# WS-Sale-App — Backend env for Coolify (Hetzner VPS)
# =============================================================
# ⚠ ชื่อตัวแปรทั้งหมดในไฟล์นี้ = ชื่อที่ "โค้ดอ่านจริง" (backend/db.js, server.js, routes/*)
#   อย่าใช้ DB_HOST / DB_PORT — โค้ดไม่รู้จัก และจะ fallback ไป IP เดิมที่ hardcode ไว้
#
# ใส่ค่าเหล่านี้ใน Coolify → Resource → Environment Variables
# =============================================================

# ── SQL Server (WINSpeed) ─────────────────────────────────────
# บน Linux/container ต้องเป็น "remote" เสมอ
# ("local" = Windows Trusted Connection → ใช้ไม่ได้บน Linux)
DB_MODE="remote"

# ชื่อ service ใน Docker network ของ Coolify (ไม่ใช่ IP)
REMOTE_DB_SERVER="mssql"
REMOTE_DB_PORT="1433"
REMOTE_DB_USER="sa"
REMOTE_DB_PASSWORD="__SAME_AS_MSSQL_SA_PASSWORD__"

DB_NAME="dbwins_worldfert9"

# ใช้โดย backend/check.js และ migration tooling (ไม่ใช่ main pool)
# main pool บน remote ใช้ REMOTE_DB_USER/PASSWORD
DB_USER="wf_reader"
DB_PASSWORD="__WF_READER_PASSWORD__"
DB_OWNER_USER="wf_owner"
DB_OWNER_PASSWORD="__WF_OWNER_PASSWORD__"

# ── LOCAL (dev บน Windows เท่านั้น — ปล่อยว่างบน Coolify) ─────
# LOCAL_DB_SERVER=
# LOCAL_DB_CONNECTION_STRING=

# ── TruckScale (MySQL) ────────────────────────────────────────
# ถ้ายังไม่ย้าย MySQL ให้ชี้ host เดิมไปก่อน (แนะนำใน Phase 2)
MYSQL_HOST="mysql"
MYSQL_PORT="3306"
MYSQL_DATABASE="db_truckscale"
MYSQL_USER="__MYSQL_USER__"
MYSQL_PASSWORD="__MYSQL_PASSWORD__"

# รอบ sync ดึงใบชั่งเข้า wf.WeighInbox (ms) — 0/ไม่ตั้ง = ใช้ค่า default 60000
TS_SYNC_INTERVAL_MS="60000"
# secret สำหรับ endpoint รับ ingest จากภายนอก (ถ้าใช้)
TS_INGEST_SECRET="__RANDOM_SECRET__"

# ── Auth ──────────────────────────────────────────────────────
# ต้องยาว >= 32 ตัวอักษร และสุ่มจริง (openssl rand -base64 48)
JWT_SECRET="__CHANGE_ME_RANDOM_MIN_32_CHARS__"
JWT_EXPIRES_IN="8h"

# ── Server ────────────────────────────────────────────────────
PORT="3000"
NODE_ENV="production"
TZ="Asia/Bangkok"

# โดเมน frontend ที่อนุญาตให้เรียก API (ไม่ตั้ง = frontend อาจโดน CORS block)
CORS_ORIGIN="https://app.yourdomain.com"

# ── Paths ─────────────────────────────────────────────────────
# ⚠ ค่าเดิมเป็น Windows path (C:\wssale-exports) — บน Linux ต้องเปลี่ยน
#   และควร mount เป็น persistent volume ถ้าต้องเก็บไฟล์ export
EXPORT_OUTPUT_PATH="/app/exports"

# ── Migrations ────────────────────────────────────────────────
# secret ป้องกัน endpoint /admin/migrate
MIGRATE_SECRET="__RANDOM_SECRET__"

# ── LINE Login (OAuth) ────────────────────────────────────────
# Callback URL ต้องตรงกับที่ตั้งใน LINE Developers Console
LINE_LOGIN_CHANNEL_ID="__LINE_LOGIN_CHANNEL_ID__"
LINE_LOGIN_CHANNEL_SECRET="__LINE_LOGIN_CHANNEL_SECRET__"
LINE_LOGIN_CALLBACK_URL="https://api.yourdomain.com/api/auth/line/callback"
LINE_LOGIN_SUCCESS_REDIRECT="https://app.yourdomain.com"

# ── LINE Messaging (ถ้าใช้แจ้งเตือน) ──────────────────────────
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=

# ── Observability (ไม่บังคับ) ─────────────────────────────────
# ALERT_WEBHOOK_URL=
APP_VERSION="1.0.0"

# ── เอกสารอ้างอิงใน workflow (ไม่บังคับ) ──────────────────────
# WF_SO_DOC=
# WF_SO_COMPARE_DOC=

# =============================================================
# FRONTEND (WSSale-App) — ตั้งที่ Vercel/Coolify ของ frontend
# ⚠ Vite bake ค่าตอน BUILD → เปลี่ยนแล้วต้อง rebuild ไม่ใช่แค่ restart
# =============================================================
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_USE_MOCKUP_DATA=false
