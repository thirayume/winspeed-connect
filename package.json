{
  "name": "winspeed-erp-root",
  "version": "1.1.0",
  "description": "Root management for Sales Order app",
  "scripts": {
    "start:backend": "cd backend && nodemon server.js",
    "start:frontend": "cd WSSale-App && npm run dev",
    "predev": "kill-port 3000 5173 || true",
    "predev:e2e": "kill-port 3100 5174 || true",
    "dev": "concurrently -n API,WEB -c blue,green \"npm run start:backend\" \"npm run start:frontend\"",
    "dev:e2e": "cross-env PORT=3100 VITE_API_BASE_URL=http://localhost:3100/api concurrently -n API,WEB -c blue,green \"npm run start:backend\" \"cd WSSale-App && npm run dev -- --force --port 5174 --strictPort\"",
    "build": "cd WSSale-App && npm install && npm run build",
    "smoke:queries": "node backend/scripts/run_query_smoke.js",
    "smoke:api": "node backend/scripts/api_smoke.js",
    "smoke:api:local": "node backend/scripts/run_local_api_smoke.js",
    "migrate": "node backend/scripts/migrate-targets.js",
    "migrate:all": "node backend/scripts/migrate-targets.js --targets all",
    "migrate:local": "node backend/scripts/migrate-targets.js --targets local",
    "migrate:remote": "node backend/scripts/migrate-targets.js --targets remote",
    "migrate:remote_b": "node backend/scripts/migrate-targets.js --targets remote_b",
    "migrate:plan": "node backend/scripts/migrate-targets.js --plan",
    "migrate:plan:local": "node backend/scripts/migrate-targets.js --targets local --plan",
    "migrate:plan:remote": "node backend/scripts/migrate-targets.js --targets remote --plan",
    "migrate:plan:remote_b": "node backend/scripts/migrate-targets.js --targets remote_b --plan",
    "test:migrations": "node --test backend/run_migrations.test.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
    "deploy:minor": "powershell -ExecutionPolicy Bypass -File deploy.ps1 -BumpType minor",
    "deploy:major": "powershell -ExecutionPolicy Bypass -File deploy.ps1 -BumpType major",
    "deploy:skip-migrate": "powershell -ExecutionPolicy Bypass -File deploy.ps1 -SkipMigration",
    "deploy:dry": "powershell -ExecutionPolicy Bypass -File deploy.ps1 -DryRun",
    "smoke": "node scripts/smoke-api.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14"
  }
}
