# ── Database (Remote SQL Server) ─────────────────────────────
DB_MODE=remote
# For local Windows Auth use LOCAL_DB_SERVER=localhost\SQLEXPRESS.
# If SQL Browser is off, use named pipe, for example:
# LOCAL_DB_SERVER=np:\\.\pipe\MSSQL$SQLEXPRESS\sql\query
REMOTE_DB_SERVER=20.255.185.14
REMOTE_DB_PORT=1433
REMOTE_DB_USER=sa
REMOTE_DB_PASSWORD=YourPasswordHere
DB_NAME=dbwins_worldfert9

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# LINE Login (OAuth)
# Callback URL in LINE Developers must match LINE_LOGIN_CALLBACK_URL.
LINE_LOGIN_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID
LINE_LOGIN_CHANNEL_SECRET=YOUR_LINE_LOGIN_CHANNEL_SECRET
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/api/auth/line/callback
LINE_LOGIN_SUCCESS_REDIRECT=http://localhost:5173

# ── CORS — comma-separated origins allowed to call the API ───
# On-premise (same machine):  http://localhost
# On-premise (LAN IP):        http://192.168.1.100
# Public domain:              https://yourdomain.com
CORS_ORIGIN=http://localhost

# ── Frontend build-time ───────────────────────────────────────
# On-premise: http://<server-ip>:3000/api
# Public:     https://api.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:3000/api
