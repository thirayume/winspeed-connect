# ── Database (Remote SQL Server) ─────────────────────────────
REMOTE_DB_SERVER=20.255.185.14
REMOTE_DB_PORT=1433
REMOTE_DB_USER=sa
REMOTE_DB_PASSWORD=YourPasswordHere
