# .env สำหรับ docker compose (คัดลอกเป็น .env ที่ root แล้วแก้ค่า)
# ─────────────────────────────────────────────────────────────

# ── SQL Server (WINSpeed + wf) ──
# โหมด external (default): ชี้ไป remote/Railway
# โหมด self-host (--profile db): ตั้ง REMOTE_DB_SERVER=sqlserver (ชื่อ service)
REMOTE_DB_SERVER=sqlserver
REMOTE_DB_PORT=1433
REMOTE_DB_USER=sa
REMOTE_DB_PASSWORD=CHANGE_ME_Strong#Passw0rd
DB_NAME=dbwins_worldfert9

# ── JWT ── (P0: สุ่มยาว ≥64 ตัวอักษร)
JWT_SECRET=CHANGE_ME_to_random_64_chars_minimum
JWT_EXPIRES_IN=8h

# ── CORS ── (P1: ใส่ domain frontend จริง ห้ามใช้ *)
CORS_ORIGIN=http://localhost:80

# ── Observability / Alerting (FR-030) ──
# webhook สำหรับแจ้งเตือน error (500) + crash + release — รองรับ Slack/Discord/Teams/generic
# เว้นว่าง = ปิดการแจ้งเตือน (telemetry/error-log ยังทำงานปกติ)
ALERT_WEBHOOK_URL=

# ── TruckScale (MySQL) ──
# external: ชี้ไป Railway · self-host (--profile db): MYSQL_HOST=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=db_truckscale
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME_Strong#MysqlP0ss

# ── Frontend build ──
VITE_API_BASE_URL=http://localhost:3000/api
