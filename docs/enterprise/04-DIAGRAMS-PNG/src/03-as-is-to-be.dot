
digraph G { graph [rankdir=LR, bgcolor="transparent", pad="0.2", ranksep="0.7"]; node [shape=rect, style="rounded,filled", fontname="Kanit", fontsize=16, color="#173B63", fillcolor="#FFFFFF", penwidth=2]; edge [fontname="Kanit", fontsize=12, color="#334155", penwidth=2];
